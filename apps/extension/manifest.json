{
  "manifest_version": 3,
  "name": "Cadence Reader",
  "description": "Read webpages aloud with click-to-read, live highlighting, and Edge TTS streamed from the local Flask app.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "offscreen",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "read-from-top": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Start reading the current page from the top"
    },
    "toggle-playback": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Pause or resume current page reading"
    }
  },
  "action": {
    "default_title": "Cadence",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
